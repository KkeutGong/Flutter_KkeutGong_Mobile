API_BASE_URL=https://kkeutgong-backend.hyphen.it.com/api

# ── Kakao OAuth ──────────────────────────────────────────────────────────────
# Get from https://developers.kakao.com → My App → App Keys → Native app key
KAKAO_NATIVE_APP_KEY=a3d2950a5b2671077fa2f1d26b5f76ac

# ── Google OAuth ──────────────────────────────────────────────────────────────
# iOS: REVERSED_CLIENT_ID comes from GoogleService-Info.plist (auto-set)
# Android: register SHA-1 fingerprint in GCP Console → OAuth 2.0 Client IDs
# Get from https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=549691983884-srbndqgvipkce8mfatt9b3jfvotuqivi.apps.googleusercontent.com

# ── Apple Sign In ─────────────────────────────────────────────────────────────
# Apple Sign In is configured in Xcode (Signing & Capabilities).
# No key required here; the SDK handles it natively on iOS 13+.

# ── Sentry ────────────────────────────────────────────────────────────────────
# Get from https://sentry.io → Project → Settings → Client Keys (DSN)
SENTRY_DSN=

# ── App Store / Play Store (for force-update screen) ─────────────────────────
# TODO: Replace with the real App Store URL once App Store Connect issues an
# app ID after the first submission. Until then, the search URL is the safest
# fallback because it never 404s.
APP_STORE_URL=https://apps.apple.com/kr/search?term=%EB%81%9D%EA%B3%B5
PLAY_STORE_URL=https://play.google.com/store/apps/details?id=com.kkeutgong.app
